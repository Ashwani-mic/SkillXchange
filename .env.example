# Server Config
PORT=3001
SESSION_SECRET=your_session_secret_here

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillxchange

# SMTP Email Configuration (Optional, for email notifications/verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=no-reply@skillxchange.com

# Gemini API Configuration (For real AI Chat & Bio skill tag extraction)
GEMINI_API_KEY=your_gemini_api_key_here
